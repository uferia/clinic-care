# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Consumed by supabase/config.toml -> [edge_runtime.secrets] for local `supabase start`.
# For deployed functions set the same names via `npx supabase secrets set ...`.

# Google Cloud Storage bucket that holds patient documents.
GCS_BUCKET=my-clinic-docs-bucket

# Service-account key JSON, on ONE line. Keep the literal \n escapes inside private_key.
GCS_SA_KEY=

# --- Stripe (subscription payments) ---------------------------------------
# Use TEST keys locally (sk_test_...). Never commit real keys; never paste them in chat.

# Secret key: Stripe Dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=

# The monthly plan every clinic subscribes to. Create a recurring PHP monthly Price in
# Stripe (Product -> Add price -> Recurring, monthly) and paste its ID (price_...), NOT
# the amount — the amount lives in Stripe so changing it needs no deploy.
STRIPE_PRICE_ID=

# Signing secret for the webhook. Locally this comes from `stripe listen` (whsec_...);
# in production it is the one shown when you add the endpoint in the Dashboard. The
# webhook trusts nothing without it.
STRIPE_WEBHOOK_SECRET=

# Where Stripe returns the clinic after checkout / the billing portal.
APP_URL=http://localhost:4200{"client_email":"docs-signer@my-project.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"}
